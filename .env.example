# JWT signing secret. Use a random value with at least 32 characters.
JWT_SECRET=replace-with-a-long-random-secret

# Maximum number of reusable MySQL connections per backend instance.
DB_POOL_SIZE=8
DB_POOL_ACQUIRE_TIMEOUT_MS=3000

# Paper storage directory. Mount persistent storage here in production.
UPLOAD_DIR=./uploads/papers

# OpenAI-compatible chat completions endpoint.
AI_API_BASE_URL=https://api.deepseek.com/chat/completions

# Do not commit your real API key.
AI_API_KEY=replace-with-your-api-key

# Example models: deepseek-v4-flash, deepseek-v4-pro, deepseek-chat.
AI_MODEL=deepseek-v4-flash

# Bound AI provider concurrency and pending work per backend instance.
AI_MAX_CONCURRENCY=4
AI_QUEUE_SIZE=32

# Windows/MSYS2 local CA bundle. Override this when deploying elsewhere.
AI_CA_BUNDLE=D:/msys64/ucrt64/etc/ssl/cert.pem
