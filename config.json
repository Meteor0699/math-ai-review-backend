{
  "listeners": [
    {
      "address": "0.0.0.0",
      "port": 8080,
      "https": false
    }
  ],
  "app": {
    "number_of_threads": 1,
    "enable_session": false,
    "log_path": "./logs",
    "logfile_base_name": "math-ai-review-backend",
    "log_size_limit": 100000000,
    "log_level": "DEBUG"
  },
  "db_clients": [
    {
      "name": "default",
      "rdbms": "mysql",
      "host": "${DB_HOST:127.0.0.1}",
      "port": ${DB_PORT:3306},
      "dbname": "${DB_NAME:math_ai_review}",
      "user": "${DB_USER:root}",
      "passwd": "${DB_PASSWORD:123456}",
      "is_fast": true,
      "number_of_connections": 1,
      "timeout": 5.0,
      "auto_batch": false,
      "properties": {
        "ssl_mode": "${DB_SSL_MODE:DISABLED}",
        "ssl_ca": "${DB_SSL_CA:}"
      }
    }
  ],
  "custom_config": {
    "jwt_secret": "change_this_secret_in_local_development",
    "jwt_expire_hours": 24,
    "upload_dir": "./uploads/papers",
    "ai": {
      "base_url": "",
      "api_key": "",
      "model": ""
    }
  }
}
